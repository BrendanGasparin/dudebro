pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--main
function _init()
	reset_game()
end

function _update()
 if game_state=="title" then
  if btn(❎) then
  	game_state="playing"
  	add_enemies_l1()
  	add_collectibles_l1()
  end
 elseif game_state=="playing" then
 	player_update()
 	player_animate()
 	update_enemies()
 	check_enemy_collisions()
 	check_coll_collisions()
 	check_level_end()
 	animate_enemies()
 	animate_collectibles()
 	camera_update()
 elseif game_state=="death" then
 	player_update()
 	player_animate()
 elseif game_state=="gameover" then
 	game_state="gameoverscreen"
 	return
 end
 
 if game_state=="gameoverscreen" then
  game_timer+=1
  if game_timer>150 then
  	game_state="title"
  	game_timer=0
  	reset_game()
  end
  return
 end
 
 if game_state=="win" then
  game_timer+=1
  if game_timer>150 then
   game_state="title"
   game_timer=0
   reset_game()
  end
  return
 end
end

function _draw()
	if game_state=="gameoverscreen" then
	 camera()
	 cls(0)
	 print("game over, man",36,16,7)
	 return
	end
	
 camera(cam.x, cam.y)
 cls(12)
 map()
 draw_enemies()
 draw_collectibles()
	spr(dude.sp,dude.x,dude.y,dude.w/8,dude.h/8,dude.flipx,dude.flipy)
	if game_state=="playing"
	or game_state=="win"
	or dude.dead then
		draw_ui()
 end
	if game_state=="title" then
		rectfill(8,12,124,48,8)
		print("dude bro",52,16,7)
		print("❎ to start",44,24,7)
		print("(c) brendan gasparin 2026",16,40,7)
	elseif game_state=="win" then
	 print("you found your dog!",cam.x+28,cam.y+24,7)
	end
end

function camera_update()
 --cam.x=dude.x-64+dude.w/2
 cam.x+=(dude.x-64-cam.x)*0.1
 if cam.x<map_start then
 	cam.x=map_start
 end
 if cam.x>map_end-128 then
 	cam.x=map_end-128
 end
end

function collide_map(obj,dir,flag)
	--obj needs x,y,w,h
	--dir="left","right","up","down"
	local x=obj.x
	local y=obj.y
	local w=obj.w
	local h=obj.h
	
	local x1=0
	local y1=0
	local x2=0
	local y2=0
	
	--check "hitbox" in direction
	if dir=="left" then
		x1=x-1
		y1=y
		x2=x-1
		y2=y+h-1
	elseif dir=="right" then
		x1=x+w
		y1=y
		x2=x+w
		y2=y+h-1
	elseif dir=="up" then
	 x1=x+1
	 y1=y-1
	 x2=x+w-1
	 y2=y-1
	elseif dir=="down" then
	 x1=x+2
	 y1=y+h
	 x2=x+w-3
	 y2=y+h
	end
	
	--pixels to tiles
	x1=flr(x1/8)
	y1=flr(y1/8)
	x2=flr(x2/8)
	y2=flr(y2/8)
	
	--fget returns true if sprite
	--matches flag
	--mget gets sprite no at tile
	--location x1,y1
	if fget(mget(x1,y1),flag)
	or fget(mget(x1,y2),flag)
	or fget(mget(x2,y1),flag)
	or fget(mget(x2,y2),flag) then
		return true
	else
	 return false
	end
end

function draw_ui()
print("score: "..dude.score,cam.x,cam.y)
print("lives: "..dude.lives,cam.x+96,cam.y)
end

function limit_speed(num, maxim)
	return mid(-maxim,num,maxim)
end

function reset_game()
	dude={
	 sp=2,
		x=80,
		y=96,
		w=8,
		h=8,
		flipx=false,
		flipy=false,
		dx=0,
		dy=0,
		max_dx=2,
		max_dy=5,
		acc=0.5,
		boost=4,
		anim=0,
		lives=2,
		level=1,
		score=0,
		running=false,
		jumping=false,
		falling=false,
		sliding=false,
		landed=false,
		dead=false,
		death_timer=0
	}
	
	grav=0.3
	friction=0.85
	
	map_start=0
	map_end=1024
	
	game_timer=0
	
	cam={
		x=0,
		y=0
	}
	camera_update()
	
	game_state="title"
end
-->8
--player code
function check_level_end()
	if collide_map(dude,"up",2)
	or collide_map(dude,"down",2)
	or collide_map(dude,"left",2)
	or collide_map(dude,"right",2) then
		game_state="win"
		dude.dx=0
		dude.dy=0
	end
end

function player_animate()
	if dude.jumping then
	 dude.sp=7
	elseif dude.falling then
		dude.sp=8	
	elseif dude.sliding then
	 dude.sp=9
	elseif dude.running then
		if time()-dude.anim>.1 then
			dude.anim=time()
			dude.sp+=1
			if dude.sp>6 then
				dude.sp=3
			end
		end
	else --player idle
		if time()-dude.anim>.2 then
			dude.anim=time()
			dude.sp+=1
			if dude.sp>2 then
				dude.sp=1
			end
		end
	end
end

function player_death()
 dude.lives-=1
 if dude.lives<0 then
  dude.lives=0
  game_timer=0
 	game_state="gameover"
 	coll={}
 	return
 end
 dude.x=80
 dude.y=96
 dude.dx=0
 dude.dy=0
 dude.dead=false
 dude.death_timer=0
 dude.flipy=false
 dude.jumping=false
 dude.falling=false
 dude.sliding=false
 dude.running=false
 dude.landed=false
 game_state="playing"
 cam.x=dude.x-64
 cam.y=0
 camera_update()
 add_enemies_l1()
 add_collectibles_l1()
end

function player_update()
	--physics
	dude.dy+=grav
	dude.dx*=friction
	
	if dude.dead then
		dude.death_timer+=1
		
		if dude.death_timer>90 then
			player_death()
		end
	end
	
	--controls
	if btn(🅾️) then
	 dude.acc=1.2
	else
		dude.acc=0.5
	end
	if btn(⬅️) and not dude.dead then
		dude.dx-=dude.acc
		dude.running=true
		dude.flipx=true
	end
	if btn(➡️) and not dude.dead then
	 dude.dx+=dude.acc
	 dude.running=true
	 dude.flipx=false
	end
	
	--slide
	if dude.running
	and not btn(⬅️)
	and not btn(➡️)
	and not dude.falling
	and not dude.jumping then
		dude.running=false
		dude.sliding=true
	end
	
	--jump
	if btnp(❎)
	and dude.landed
	and not dude.dead then
		dude.dy-=dude.boost
		dude.landed=false
		sfx(0)
	end
	
	--check collision up and down
	if dude.dy>0 then
		dude.falling=true
		dude.landed=false
		dude.jumping=false
		
		dude.dy=limit_speed(dude.dy,dude.max_dy)
		
	elseif dude.dy<0 and dude.dead==false then
		dude.jumping=true
		if collide_map(dude,"up",1) and dude.dead==false then
			dude.dy=0
		end
	end
	
	--move horizontally b4 coll
	--detection
	dude.x+=dude.dx
	
	--check collision left and right
	if dude.dx<0 then
		dude.dx=limit_speed(dude.dx,dude.max_dx)
		if collide_map(dude,"left",1) then
			dude.dx=0
			dude.x=flr((dude.x-1)/8)*8+8
		end
	elseif dude.dx>0 then
	 dude.dx=limit_speed(dude.dx,dude.max_dx)
		if collide_map(dude,"right",1) then
			dude.dx=0
			dude.x=flr((dude.x+dude.w)/8)*8-dude.w
		end
	end
	
	--move vertically
	dude.y+=dude.dy
	
			-- check collision down
	if collide_map(dude,"down",0) and dude.dead==false then
		dude.landed=true
		dude.falling=false
		dude.dy=0
		dude.y-=(dude.y+dude.h)%8--don't fall through ground
	end
	
	--check if fell to death
	if dude.y>128 and dude.dead==false then
		dude.dead=true
		sfx(1)
		dude.death_timer=0
		game_state="death"
		dude.flipy=true
		dude.dy=0
		dude.dy-=dude.boost
		dude.dx=0
		dude.landed=false
	end
	
	--stop sliding
	if dude.sliding then
		if abs(dude.dx)<.2
		or dude.running then
			dude.dx=0
			dude.sliding=false
		end
	end
	
	--keep dude in map bounds
	if dude.x<map_start then
	 dude.x=map_start
	elseif dude.x>map_end-dude.w then
		dude.x=map_end-dude.w
	end
	
end

--enemy code
enemies={}

function add_enemies_l1()
	enemies={}
	spawn_pig(224,96)
	spawn_pig(384,96)
	spawn_pig(456,96)
	spawn_pig(576,96)
	spawn_pig(656,96)
	spawn_pig(736,96)
	spawn_pig(776,96)
end

function animate_enemies()
	for e in all(enemies) do
		if e.alive and e.active then
		 animate_enemy(e)
		end
	end
end

function animate_enemy(e)
	if e.active==true then
		if time()-e.anim>.2 then
			e.anim=time()
			e.sp+=1
			if e.sp>49 then
				e.sp=48
			end
		end
	end
end

function box_collide(a,b)
	return a.x<b.x+b.w
	and a.x+a.w>b.x
	and a.y<b.y+b.h
	and a.y+a.h>b.y
end

function check_enemy_collisions()
	for e in all(enemies) do
		if e.alive
		and e.active
		and not dude.dead then
			if box_collide(dude,e) then
				dude.dead=true
				sfx(1)
				dude.death_timer=0
				game_state="death"
				dude.flipy=true
				dude.dy=-dude.boost
				dude.dx=0
			end
		end
	end
end

function draw_enemies()
	for e in all(enemies) do
	 if e.alive and e.active then
	 	spr(e.sp,e.x,e.y,e.w/8,e.h/8,e.flipx)
	 end
	end
end

function spawn_pig(xcoord,ycoord)
	add(enemies,{
		x=xcoord,
		y=ycoord,
		w=8,
		h=8,
		dx=-0.5,
		dy=0,
		sp=48,
		flipx=true,
		type="pig",
		alive=true,
		active=false,
		anim=0,
		anim_length=2
	})
end

function update_enemies()
	for e in all(enemies) do
		if e.alive then
		 if e.x>cam.x
		 and e.x<cam.x+128
		 and e.active==false then
		 	e.active=true
			end
			if e.active then
				update_enemy(e)
			end
		end
	end
end

function update_enemy(e)
	e.dy+=grav
	e.x+=e.dx
	e.y+=e.dy

	if collide_map(e, "left", 0) or collide_map(e,"right",1) then
		e.dx*=-1
	end
	if collide_map(e,"down",0) then
		e.dy=0
		e.y-=(e.y+e.h)%8
	end
	if e.dx<0 then
		e.flipx=true
	else
	 e.flipx=false
	end
end

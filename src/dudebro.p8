coll={}

function add_collectibles_l1()
	coll={}
	
	spawn_coin(0,56)
	spawn_coin(50,50)
	spawn_coin(25*8,56)
	spawn_coin(34*8,56)
	spawn_coin(37*8,80)
	spawn_coin(39*8,80)
	spawn_coin(41*8,80)
	spawn_coin(45*8,72)
	spawn_coin(48*8,72)
	spawn_coin(51*8,72)
	spawn_coin(54*8,64)
	spawn_coin(58*8,40)
	spawn_coin(58*8,80)
	spawn_coin(60*8,40)
	spawn_coin(60*8,80)
	spawn_coin(62*8,40)
	spawn_coin(62*8,80)
	spawn_coin(66*8,16)
	spawn_coin(69*8,80)
	spawn_coin(71*8,80)
	spawn_coin(73*8,80)
	spawn_coin(73*8,16)
	spawn_coin(80*8,16)
	spawn_coin(88*8,80)
	spawn_coin(91*8,80)
	spawn_coin(94*8,80)
	spawn_coin(97*8,80)
	spawn_coin(100*8,80)
	--spawn_coin(103*8,80)
end

function animate_collectibles()
	for c in all(coll) do
		if c.active then
		 animate_collectible(c)
		end
	end
end

function animate_collectible(c)
	if c.active==true then
		if time()-c.anim>.2 then
			c.anim=time()
			c.sp+=1
			if c.sp>66 then
				c.sp=64
			end
		end
	end
end

function check_coll_collisions()
	for c in all(coll) do
		if c.active
		and not dude.dead then
			if box_collide(dude,c) then
				dude.score+=100
				c.active=false
				sfx(2)
			end
		end
	end
end

function draw_collectibles()
	for c in all(coll) do
		if c.active then
			spr(c.sp,c.x,c.y)
		end
	end
end

function spawn_coin(xcoord,ycoord)
	add(coll,{
	 x=xcoord,
	 y=ycoord,
	 w=8,
	 h=8,
	 sp=64,
	 active=true,
	 anim=0
	})
	
end
